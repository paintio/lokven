generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  email         String?  @unique
  password      String
  name          String?
  avatar        String?
  role          String   @default("user")
  isBlocked     Boolean  @default(false)
  isVerified    Boolean  @default(false)
  isSeller      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  
  inn           String?
  ogrn          String?
  companyName   String?
  legalAddress  String?
  bankAccount   String?
  bik           String?
  documents     Json?
  sellerStatus  String   @default("pending")
  
  resetToken    String?
  resetTokenExpiry DateTime?
  
  listings      Listing[]
  messagesFrom  Message[] @relation("SenderMessages")
  messagesTo    Message[] @relation("ReceiverMessages")
  favorites     Favorite[]
  ordersAsBuyer Order[]   @relation("BuyerOrders")
  ordersAsSeller Order[]  @relation("SellerOrders")
  payments      Payment[]
  sessions      Session[]
  notifications Notification[]
  reviewsAsSeller Review[] @relation("SellerReviews")
  reviewsAsBuyer  Review[] @relation("BuyerReviews")
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  text        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  reviewerId  String
  reviewer    User     @relation("BuyerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  
  sellerId    String
  seller      User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Listing {
  id            String   @id @default(cuid())
  title         String
  description   String?
  price         Float
  currency      String   @default("RUB")
  type          String
  attributes    Json
  lat           Float?
  lng           Float?
  address       String?
  status        String   @default("pending")
  views         Int      @default(0)
  isPremium     Boolean  @default(false)
  premiumUntil  DateTime?
  moderationNote String?
  moderationAt  DateTime?
  moderationBy  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  images        Image[]
  favorites     Favorite[]
  messages      Message[]
  orders        Order[]
  reviews       Review[]
}

model Image {
  id          String   @id @default(cuid())
  url         String
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  @@unique([userId, listingId])
}

model Message {
  id          String   @id @default(cuid())
  text        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  senderId    String
  receiverId  String
  
  sender      User     @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  parentId    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  parent      Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryParent")
}

model Tax {
  id          String   @id @default(cuid())
  name        String
  rate        Float
  type        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Order {
  id          String   @id @default(cuid())
  status      String   @default("pending")
  total       Float
  tax         Float
  commission  Float
  netTotal    Float
  
  buyerId     String
  sellerId    String
  listingId   String
  
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  seller      User     @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  payment     Payment?
  review      Review?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  status      String   @default("pending")
  method      String
  transactionId String?
  orderId     String   @unique
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  userId      String?
  details     Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model SiteSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  group       String
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String?  // HTML контент страницы
  metaTitle   String?
  metaDescription String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model FooterLink {
  id          String   @id @default(cuid())
  group       String
  label       String
  url         String
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([group, label])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  group       String
  type        String   @default("string")
  label       String?
  description String?
  updatedAt   DateTime @default(now()) @updatedAt
}
